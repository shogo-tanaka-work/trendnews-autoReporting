# Slack Bot Token (xoxb- で始まるBot User OAuth Token)
SLACK_BOT_TOKEN=xoxb-your-token-here

# 通知先のSlackチャンネルID (カテゴリごとに設定)
SLACK_CHANNEL_AI_NEWS=C0AJ4PB4DJR
SLACK_CHANNEL_ENGINEER_NEWS=C0AJM3X7CUR
SLACK_CHANNEL_WHISKEY_NEWS=C0AK2TVJA9W
SLACK_CHANNEL_FITNESS_NEWS=C0XXXXXXXXX
SLACK_CHANNEL_BUSINESS_NEWS=C0XXXXXXXXX
SLACK_CHANNEL_ECONOMY_NEWS=C0XXXXXXXXX

# カテゴリごとの実行スケジュール (cron形式)
# 未設定の場合は全カテゴリ共通で「毎日 8:00 と 20:00」がデフォルト
CRON_AI_NEWS=0 8,20 * * *
CRON_ENGINEER_NEWS=0 8,20 * * *
CRON_WHISKEY_NEWS=0 22 * * *
CRON_FITNESS_NEWS=0 17 * * *
CRON_BUSINESS_NEWS=0 8 * * *
CRON_ECONOMY_NEWS=0 8,20 * * *

# フィルタリング期間 (時間単位, デフォルト: 24)
# FILTER_HOURS=24
